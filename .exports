# Fix less to work with formatting.
LESS=-FRX;
export LESS

# Path configuration
export PATH=/usr/local/opt/ruby/bin:/usr/local/bin:/usr/local/sbin:/usr/bin:/bin:/usr/sbin:/sbin:/usr/X11/bin:$HOME/.cargo/bin:$HOME/.local/bin:$PATH

# CLI Colors
export CLICOLOR=1

# History Control
export HISTCONTROL=ignoredups
export HISTCONTROL=ignoreboth
export HISTTIMEFORMAT='%Y-%m-%d %H:%M:%S '
export HISTFILESIZE=2000
export HISTIGNORE="[ ]*:&:bg:fg:exit" # Ignore some controlling instructions
export PROMPT_COMMAND="history -a"

# Configure ccache
export CCACHE_COMPRESS=""

# Configure tools to use light terminals.
BAT_THEME=GitHub

# Configure pyenv before the plugin is loaded.
export PYENV_ROOT="$HOME/.pyenv"
export PATH="$PYENV_ROOT/bin:$PATH"
eval "$(pyenv init --path)"
eval "$(pyenv virtualenv-init -)"
